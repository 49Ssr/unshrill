<Application x:Class="Unshrill.App.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	StartupUri="MainWindow.xaml">
	<Application.Resources>
		<SolidColorBrush x:Key="CanvasBrush" Color="#111417" />
		<SolidColorBrush x:Key="PanelBrush" Color="#1A1F23" />
		<SolidColorBrush x:Key="PrimaryBrush" Color="#E9F0EB" />
		<SolidColorBrush x:Key="MutedBrush" Color="#9EAAA2" />
		<SolidColorBrush x:Key="AccentBrush" Color="#8ED6B0" />
	</Application.Resources>
</Application>

