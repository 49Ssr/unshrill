<Window x:Class="Unshrill.App.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Unshrill"
	Width="920"
	Height="580"
	MinWidth="760"
	MinHeight="500"
	Background="{StaticResource CanvasBrush}"
	Foreground="{StaticResource PrimaryBrush}"
	WindowStartupLocation="CenterScreen">
	<Grid Margin="36">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="32" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<StackPanel>
			<TextBlock FontSize="36" FontWeight="SemiBold" Text="Unshrill" />
			<TextBlock Margin="0,8,0,0"
				Foreground="{StaticResource MutedBrush}"
				FontSize="15"
				Text="Make Windows audio easier to live with." />
		</StackPanel>

		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="20" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Border Padding="24" Background="{StaticResource PanelBrush}" CornerRadius="14">
				<StackPanel>
					<TextBlock FontSize="13" Foreground="{StaticResource AccentBrush}" Text="CONTROL PLANE" />
					<TextBlock Margin="0,12,0,0" FontSize="22" FontWeight="SemiBold" Text="Audio sessions" />
					<TextBlock Margin="0,12,0,0"
						Foreground="{StaticResource MutedBrush}"
						LineHeight="22"
						TextWrapping="Wrap"
						Text="The foundation is ready for Core Audio discovery, persistent per-application volume rules, and device-aware recovery." />
					<Border Margin="0,24,0,0" Padding="14" BorderBrush="#33413A" BorderThickness="1" CornerRadius="8">
						<TextBlock Foreground="{StaticResource MutedBrush}" Text="No live session service is connected yet." />
					</Border>
				</StackPanel>
			</Border>

			<Border Grid.Column="2" Padding="24" Background="{StaticResource PanelBrush}" CornerRadius="14">
				<StackPanel>
					<TextBlock FontSize="13" Foreground="{StaticResource AccentBrush}" Text="COMFORT LAYER" />
					<TextBlock Margin="0,12,0,0" FontSize="22" FontWeight="SemiBold" Text="Gentle by design" />
					<TextBlock Margin="0,12,0,0"
						Foreground="{StaticResource MutedBrush}"
						LineHeight="22"
						TextWrapping="Wrap"
						Text="A tested high-shelf primitive is isolated from deployment. Endpoint processing stays disabled until its scope and bypass are explicit." />
					<StackPanel Margin="0,25,0,0" Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center" Text="Mercy Mode" />
						<ToggleButton Margin="18,0,0,0" Width="46" Height="24" IsEnabled="False" ToolTip="DSP backend not connected" />
					</StackPanel>
				</StackPanel>
			</Border>
		</Grid>

		<TextBlock Grid.Row="3"
			Margin="0,28,0,0"
			Foreground="{StaticResource MutedBrush}"
			Text="Foundation build - ordinary Windows audio remains untouched" />
	</Grid>
</Window>
