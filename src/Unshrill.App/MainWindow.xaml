<Window x:Class="Unshrill.App.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Unshrill"
	Width="1040"
	Height="700"
	MinWidth="840"
	MinHeight="560"
	Background="{StaticResource CanvasBrush}"
	Foreground="{StaticResource PrimaryBrush}"
	WindowStartupLocation="CenterScreen">
	<Window.Resources>
		<Style x:Key="QuietButton" TargetType="Button">
			<Setter Property="Padding" Value="14,8" />
			<Setter Property="Background" Value="#26302B" />
			<Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
			<Setter Property="BorderBrush" Value="#3B4A42" />
			<Setter Property="BorderThickness" Value="1" />
		</Style>
		<Style x:Key="MuteToggle" TargetType="ToggleButton">
			<Setter Property="Width" Value="62" />
			<Setter Property="Height" Value="32" />
			<Setter Property="Margin" Value="16,0,0,0" />
			<Setter Property="Background" Value="#26302B" />
			<Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
			<Setter Property="BorderBrush" Value="#3B4A42" />
			<Setter Property="BorderThickness" Value="1" />
			<Style.Triggers>
				<Trigger Property="IsChecked" Value="True">
					<Setter Property="Content" Value="Muted" />
					<Setter Property="Background" Value="#694247" />
					<Setter Property="BorderBrush" Value="#A86670" />
				</Trigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>

	<Grid Margin="32">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="24" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<StackPanel>
				<TextBlock FontSize="36" FontWeight="SemiBold" Text="Unshrill" />
				<TextBlock Margin="0,7,0,0"
					Foreground="{StaticResource MutedBrush}"
					FontSize="15"
					Text="Make Windows audio easier to live with." />
			</StackPanel>
			<StackPanel Grid.Column="1" HorizontalAlignment="Right">
				<Button x:Name="RefreshButton"
					Style="{StaticResource QuietButton}"
					Click="Refresh_Click"
					Content="Refresh now" />
				<TextBlock x:Name="SessionCountText"
					Margin="0,8,0,0"
					HorizontalAlignment="Right"
					Foreground="{StaticResource MutedBrush}"
					Text="Waiting for sessions" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="20" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Border Padding="22" Background="{StaticResource PanelBrush}" CornerRadius="14">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<StackPanel>
						<TextBlock FontSize="13" Foreground="{StaticResource AccentBrush}" Text="LIVE CONTROL" />
						<TextBlock Margin="0,9,0,0" FontSize="22" FontWeight="SemiBold" Text="Default output sessions" />
						<TextBlock x:Name="EndpointNameText"
							Margin="0,6,0,0"
							Foreground="{StaticResource MutedBrush}"
							Text="Discovering the current device..."
							TextTrimming="CharacterEllipsis" />
					</StackPanel>

					<Grid Grid.Row="2">
						<ListBox ItemsSource="{Binding Sessions}"
							Background="Transparent"
							BorderThickness="0"
							HorizontalContentAlignment="Stretch"
							ScrollViewer.HorizontalScrollBarVisibility="Disabled">
							<ListBox.ItemContainerStyle>
								<Style TargetType="ListBoxItem">
									<Setter Property="Padding" Value="0" />
									<Setter Property="Margin" Value="0,0,0,10" />
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="BorderThickness" Value="0" />
									<Setter Property="HorizontalContentAlignment" Value="Stretch" />
									<Setter Property="Focusable" Value="False" />
								</Style>
							</ListBox.ItemContainerStyle>
							<ListBox.ItemTemplate>
								<DataTemplate>
									<Border Padding="14" Background="#22292D" CornerRadius="9">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="1.15*" />
												<ColumnDefinition Width="1.35*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>
											<StackPanel VerticalAlignment="Center">
												<TextBlock FontSize="15"
													FontWeight="SemiBold"
													Text="{Binding DisplayName}"
													TextTrimming="CharacterEllipsis" />
												<TextBlock Margin="0,4,0,0"
													Foreground="{StaticResource MutedBrush}"
													FontSize="12"
													Text="{Binding ExecutableName}"
													TextTrimming="CharacterEllipsis" />
											</StackPanel>
											<Grid Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="48" />
												</Grid.ColumnDefinitions>
												<Slider Minimum="0"
													Maximum="100"
													SmallChange="1"
													LargeChange="5"
													Value="{Binding VolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
												<TextBlock Grid.Column="1"
													HorizontalAlignment="Right"
													VerticalAlignment="Center"
													Foreground="{StaticResource MutedBrush}"
													Text="{Binding VolumeText}" />
											</Grid>
											<ToggleButton Grid.Column="2"
												Style="{StaticResource MuteToggle}"
												Content="Mute"
												IsChecked="{Binding IsMuted, Mode=TwoWay}" />
										</Grid>
									</Border>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>

						<Border x:Name="EmptyState" Padding="20" BorderBrush="#33413A" BorderThickness="1" CornerRadius="9">
							<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
								<TextBlock HorizontalAlignment="Center" FontSize="16" Text="No audio sessions yet" />
								<TextBlock Margin="0,7,0,0"
									Foreground="{StaticResource MutedBrush}"
									Text="Play audio in another application to make it appear." />
							</StackPanel>
						</Border>
					</Grid>
				</Grid>
			</Border>

			<Border Grid.Column="2" Padding="22" Background="{StaticResource PanelBrush}" CornerRadius="14">
				<StackPanel>
					<TextBlock FontSize="13" Foreground="{StaticResource AccentBrush}" Text="COMFORT LAYER" />
					<TextBlock Margin="0,9,0,0" FontSize="22" FontWeight="SemiBold" Text="Gentle by design" />
					<TextBlock Margin="0,12,0,0"
						Foreground="{StaticResource MutedBrush}"
						LineHeight="22"
						TextWrapping="Wrap"
						Text="The live mixer is deliberately separate from frequency treatment. Mercy Mode stays disabled until its endpoint-wide scope and bypass are proven." />
					<Border Margin="0,24,0,0" Padding="14" BorderBrush="#33413A" BorderThickness="1" CornerRadius="8">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<StackPanel>
								<TextBlock Text="Mercy Mode" />
								<TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontSize="12" Text="Not connected" />
							</StackPanel>
							<ToggleButton Grid.Column="1" Width="46" Height="24" IsEnabled="False" />
						</Grid>
					</Border>
					<TextBlock Margin="0,22,0,0"
						Foreground="{StaticResource MutedBrush}"
						LineHeight="20"
						TextWrapping="Wrap"
						Text="This test build controls shared-mode sessions on the current default multimedia output. Exclusive-mode audio will not appear." />
				</StackPanel>
			</Border>
		</Grid>

		<Grid Grid.Row="3" Margin="0,22,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
			<TextBlock x:Name="StatusText"
				Grid.Column="1"
				Margin="10,0,0,0"
				Foreground="{StaticResource MutedBrush}"
				Text="Starting live session monitor..." />
		</Grid>
	</Grid>
</Window>
