<Window x:Class="Unshrill.App.AnalysisWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Unshrill audio research workbench"
	Width="1120"
	Height="700"
	MinWidth="900"
	MinHeight="560"
	Background="{StaticResource CanvasBrush}"
	Foreground="{StaticResource PrimaryBrush}"
	WindowStartupLocation="CenterOwner">
	<Grid Margin="28">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="18" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="18" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<StackPanel>
				<TextBlock FontSize="13" Foreground="{StaticResource AccentBrush}" Text="OFFLINE MEASUREMENT" />
				<TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="SemiBold" Text="Candidate events" />
				<TextBlock x:Name="FileNameText"
					Margin="0,6,0,0"
					Foreground="{StaticResource MutedBrush}"
					TextTrimming="CharacterEllipsis" />
			</StackPanel>
			<Button Grid.Column="1"
				Padding="14,8"
				Background="#26302B"
				Foreground="{StaticResource PrimaryBrush}"
				BorderBrush="#3B4A42"
				Click="CopyReport_Click"
				Content="Copy report" />
		</Grid>

		<Border Grid.Row="2" Padding="16" Background="{StaticResource PanelBrush}" CornerRadius="10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<StackPanel>
					<TextBlock Foreground="{StaticResource MutedBrush}" Text="Format" />
					<TextBlock x:Name="FormatText" Margin="0,4,0,0" FontSize="16" />
				</StackPanel>
				<StackPanel Grid.Column="1">
					<TextBlock Foreground="{StaticResource MutedBrush}" Text="Duration" />
					<TextBlock x:Name="DurationText" Margin="0,4,0,0" FontSize="16" />
				</StackPanel>
				<StackPanel Grid.Column="2">
					<TextBlock Foreground="{StaticResource MutedBrush}" Text="Peak frame RMS" />
					<TextBlock x:Name="PeakText" Margin="0,4,0,0" FontSize="16" />
				</StackPanel>
				<StackPanel Grid.Column="3">
					<TextBlock Foreground="{StaticResource MutedBrush}" Text="Candidates" />
					<TextBlock x:Name="CandidateCountText" Margin="0,4,0,0" FontSize="16" />
				</StackPanel>
			</Grid>
		</Border>

		<Grid Grid.Row="4">
			<DataGrid x:Name="EventsGrid"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				CanUserAddRows="False"
				CanUserDeleteRows="False"
				CanUserReorderColumns="True"
				GridLinesVisibility="Horizontal"
				HeadersVisibility="Column"
				AlternatingRowBackground="#20272B"
				Background="{StaticResource PanelBrush}"
				Foreground="{StaticResource PrimaryBrush}"
				BorderBrush="#33413A"
				HorizontalGridLinesBrush="#33413A"
				RowBackground="#1A1F23">
				<DataGrid.Columns>
					<DataGridTextColumn Width="120" Header="Time" Binding="{Binding Time}" />
					<DataGridTextColumn Width="85" Header="Length" Binding="{Binding Duration}" />
					<DataGridTextColumn Width="70" Header="Score" Binding="{Binding Score}" />
					<DataGridTextColumn Width="190" Header="Signatures" Binding="{Binding Signature}" />
					<DataGridTextColumn Width="85" Header="Level" Binding="{Binding Level}" />
					<DataGridTextColumn Width="90" Header="Rise" Binding="{Binding Emergence}" />
					<DataGridTextColumn Width="85" Header="5-10 kHz" Binding="{Binding FocusShare}" />
					<DataGridTextColumn Width="85" Header="Centroid" Binding="{Binding Centroid}" />
					<DataGridTextColumn Width="80" Header="Flatness" Binding="{Binding Flatness}" />
					<DataGridTextColumn Width="90" Header="Peak tone" Binding="{Binding Dominant}" />
					<DataGridTextColumn Width="95" Header="Prominence" Binding="{Binding Prominence}" />
				</DataGrid.Columns>
			</DataGrid>
			<Border x:Name="EmptyState" Padding="24" Background="{StaticResource PanelBrush}" CornerRadius="10">
				<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
					<TextBlock HorizontalAlignment="Center" FontSize="18" Text="No candidates crossed the current research threshold" />
					<TextBlock Margin="0,8,0,0"
						Foreground="{StaticResource MutedBrush}"
						Text="That does not prove the recording contains no unpleasant sound."
						TextWrapping="Wrap" />
				</StackPanel>
			</Border>
		</Grid>

		<Grid Grid.Row="5" Margin="0,18,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Foreground="{StaticResource MutedBrush}"
				LineHeight="18"
				TextWrapping="Wrap"
				Text="These are signal candidates, not diagnoses or universal judgments of annoyance. Bright, tonal, transient, and sudden-emergence signatures can also occur in wanted audio." />
			<Button Grid.Column="1"
				Margin="18,0,0,0"
				Padding="16,8"
				Background="#26302B"
				Foreground="{StaticResource PrimaryBrush}"
				BorderBrush="#3B4A42"
				Click="Close_Click"
				Content="Close" />
		</Grid>
	</Grid>
</Window>
